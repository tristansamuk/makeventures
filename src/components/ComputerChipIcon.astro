---
interface Props {
	class?: string;
}
const { class: className } = Astro.props;
---

<svg
	class:list={['chip-svg', className]}
	viewBox="0 0 24 24"
	xmlns="http://www.w3.org/2000/svg"
	fill="none"
	stroke="currentColor"
	stroke-miterlimit="10"
	stroke-width="1.92"
	aria-hidden="true"
>
	<rect class="chip-outer" x="3.38" y="3.38" width="17.25" height="17.25" rx="2.18" />
	<rect class="chip-inner" x="7.21" y="7.21" width="9.58" height="9.58" rx="1.92" />
	<line class="chip-pin" x1="7.21" y1="0.5" x2="7.21" y2="2.42" />
	<line class="chip-pin" x1="12" y1="0.5" x2="12" y2="2.42" />
	<line class="chip-pin" x1="16.79" y1="0.5" x2="16.79" y2="2.42" />
	<line class="chip-pin" x1="7.21" y1="21.58" x2="7.21" y2="23.5" />
	<line class="chip-pin" x1="12" y1="21.58" x2="12" y2="23.5" />
	<line class="chip-pin" x1="16.79" y1="21.58" x2="16.79" y2="23.5" />
	<line class="chip-pin" x1="0.5" y1="16.79" x2="2.42" y2="16.79" />
	<line class="chip-pin" x1="0.5" y1="12" x2="2.42" y2="12" />
	<line class="chip-pin" x1="0.5" y1="7.21" x2="2.42" y2="7.21" />
	<line class="chip-pin" x1="21.58" y1="16.79" x2="23.5" y2="16.79" />
	<line class="chip-pin" x1="21.58" y1="12" x2="23.5" y2="12" />
	<line class="chip-pin" x1="21.58" y1="7.21" x2="23.5" y2="7.21" />
</svg>

<style>
	/* Outer rect: perimeter ≈ 69 units */
	.chip-outer {
		stroke-dasharray: 70;
		stroke-dashoffset: 70;
		animation: draw 0.75s cubic-bezier(0.4, 0, 0.2, 1) forwards;
	}

	/* Inner rect: perimeter ≈ 38 units */
	.chip-inner {
		stroke-dasharray: 39;
		stroke-dashoffset: 39;
		animation: draw 0.55s cubic-bezier(0.4, 0, 0.2, 1) forwards;
		animation-delay: 0.5s;
	}

	/* Pins: too short to draw, fade in after both rects are done */
	.chip-pin {
		opacity: 0;
		animation: pinIn 0.4s ease forwards;
		animation-delay: 0.85s;
	}

	@keyframes draw {
		to { stroke-dashoffset: 0; }
	}

	@keyframes pinIn {
		to { opacity: 1; }
	}

	@media (prefers-reduced-motion: reduce) {
		.chip-outer,
		.chip-inner {
			stroke-dasharray: unset;
			stroke-dashoffset: unset;
			animation: none;
		}
		.chip-pin {
			opacity: 1;
			animation: none;
		}
	}
</style>
