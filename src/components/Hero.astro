---
import { readFileSync } from 'node:fs';
import { resolve } from 'node:path';
import { SITE_DESCRIPTION } from '../consts';

const logoSvg = readFileSync(resolve('src/assets/mv-logo.svg'), 'utf-8')
	.replace(/\s+width="[^"]*"/, '')
	.replace(/\s+height="[^"]*"/, '');
---

<section class="hero">
	<div class="hero-logo" set:html={logoSvg}></div>
	<div class="hero-right">
		<h1 class="hero-title" id="hero-title">
			<span class="title-line">
				<p class="logo-green">Make</p><p class="logo-blue">Ventures</p>
			</span>
		</h1>
		<p class="hero-description">{SITE_DESCRIPTION}</p>
	</div>
</section>

<script>
	// Scale hero title so the widest line fills the right column width
	function fitTitle() {
		const title = document.getElementById('hero-title') as HTMLElement;
		if (!title) return;
		const containerWidth = title.offsetWidth;
		const lines = title.querySelectorAll<HTMLElement>('.title-line');
		let lo = 10, hi = 400;
		title.style.fontSize = hi + 'px';
		while (hi - lo > 0.5) {
			const mid = (lo + hi) / 2;
			title.style.fontSize = mid + 'px';
			const maxWidth = Math.max(...Array.from(lines).map((l) => l.scrollWidth));
			if (maxWidth <= containerWidth) lo = mid;
			else hi = mid;
		}
		title.style.fontSize = lo + 'px';
		title.classList.add('fitted');
	}

	document.fonts.ready.then(() => requestAnimationFrame(fitTitle));
	window.addEventListener('resize', fitTitle);
	window.visualViewport?.addEventListener('resize', fitTitle);
</script>

<style>
	.hero {
		display: flex;
		align-items: center;
		gap: var(--sp-8);
		padding: var(--sp-24) 0;
		animation: fadeUp 0.6s cubic-bezier(0.22, 1, 0.36, 1) both;
		animation-delay: 0.05s;
	}
	.hero-logo {
		flex: 0 0 17.5%;
		aspect-ratio: 1;

	}
	@media (max-width: 1000px ) {
		.hero-logo {
			flex: 0 0 20%;
			aspect-ratio: 1;
		}
	}
	.hero-logo svg {
		width: 100%;
		height: 100%;
	}
	.hero-right {
		display: flex;
		flex-direction: column;
		gap: var(--sp-4);
		flex: 1;
		min-width: 0;
	}
	.hero-title {
		font-family: var(--font-display);
		font-weight: 400;
		line-height: 0.75;
		letter-spacing: -0.06em;
		margin: 0;
		display: flex;
		flex-direction: column;
		visibility: hidden;
	}
	.hero-title.fitted {
		visibility: visible;
	}
	.title-line {
		display: block;
		white-space: nowrap;
	}
	.logo-green {
		display: inline;
		color: var(--color-brand-green);
	}
	.logo-blue {
		display: inline;
		color: var(--color-brand-blue);
	}
	.hero-description {
		font-size: var(--fs-lg);
		color: var(--color-ink-muted);
		line-height: 1.7;
		margin: 0;
	}

	@media (max-width: 768px) {
		.hero {
			flex-direction: column;
			align-items: center;
			padding: var(--sp-10) 0 var(--sp-12);
		}
		/* .hero-logo {
			flex-basis: 60%;
		} */

		.hero-logo {
		width: 60%;
    aspect-ratio: 1;
		}
	.hero-right {
			width: 100%;
		}
		.hero-description {
			font-size: var(--fs-md);
		}
	}

	@keyframes fadeUp {
		from { opacity: 0; transform: translateY(8px); }
		to   { opacity: 1; transform: translateY(0); }
	}

	@media (prefers-reduced-motion: reduce) {
		.hero { animation: none; }
	}
</style>
