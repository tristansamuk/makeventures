---
import { Image } from 'astro:assets';
import type { CollectionEntry } from 'astro:content';
import BaseHead from '../components/BaseHead.astro';
import Footer from '../components/Footer.astro';
import FormattedDate from '../components/FormattedDate.astro';
import Header from '../components/Header.astro';
import StatusBadge from '../components/StatusBadge.astro';

type Props = CollectionEntry<'projects'>['data'];

const { title, description, heroImage, status, completedDate, featuredStat } = Astro.props;
---

<html lang="en">
	<head>
		<BaseHead title={title} description={description} image={heroImage} />
	</head>

	<body>
		<Header />
		<main>
			<article>
				{heroImage ? (
					<div class="project-hero">
						<Image
							width={1920}
							height={823}
							src={heroImage}
							alt=""
							class="hero-img"
						/>
						<div class="hero-overlay">
							<div class="hero-inner">
								{status && <StatusBadge {status} class="hero-status" />}
								<h1 class="hero-title">{title}</h1>
								{featuredStat && (
									<p class="hero-stat">{featuredStat}</p>
								)}
							</div>
						</div>
					</div>
				) : (
					<div class="project-header-text">
						<h1>{title}</h1>
						{featuredStat && (
							<p class="hero-stat-inline">{featuredStat}</p>
						)}
					</div>
				)}

				<div class="project-meta-bar">
					<div class="project-meta-inner">
						{status && <StatusBadge {status} />}
						{completedDate && (
							<time class="meta-date">
								<FormattedDate date={completedDate} />
							</time>
						)}
					</div>
				</div>

				<div class="prose project-prose">
					<slot />
				</div>
			</article>
		</main>
		<Footer />
	</body>
</html>

<style>
	main {
		padding-top: 0;
		padding-bottom: var(--sp-24);
	}

	/* ── Hero ── */
	.project-hero {
		position: relative;
		width: 100vw;
		left: 50%;
		transform: translateX(-50%);
		aspect-ratio: 21 / 9;
		overflow: hidden;
		margin-bottom: 0;
	}
	.hero-img {
		width: 100%;
		height: 100%;
		object-fit: cover;
		border-radius: 0;
		display: block;
	}
	.hero-overlay {
		position: absolute;
		inset: 0;
		background: linear-gradient(
			to bottom,
			transparent 30%,
			rgba(0, 0, 0, 0.72) 100%
		);
		display: flex;
		align-items: flex-end;
	}
	.hero-inner {
		max-width: var(--container);
		width: 100%;
		margin: 0 auto;
		padding: var(--sp-12) var(--sp-6);
	}
	.hero-status {
		display: inline-block;
		font-family: var(--font-mono);
		font-size: var(--fs-xs);
		font-weight: 500;
		text-transform: lowercase;
		padding: 3px var(--sp-3);
		border-radius: var(--radius-pill);
		border: 1px solid rgba(255, 255, 255, 0.3);
		color: rgba(250, 250, 250, 0.9);
		background: rgba(255, 255, 255, 0.12);
		margin-bottom: var(--sp-4);
	}
	.hero-title {
		font-family: var(--font-display);
		font-size: var(--fs-4xl);
		font-weight: 700;
		line-height: 1.1;
		color: #FAFAFA;
		margin: 0 0 var(--sp-3) 0;
	}
	.hero-stat {
		font-family: var(--font-mono);
		font-size: var(--fs-2xl);
		font-weight: 500;
		color: rgba(250, 250, 250, 0.8);
		margin: 0;
	}

	/* ── Fallback header (no image) ── */
	.project-header-text {
		max-width: var(--prose);
		margin: 0 auto;
		padding: var(--sp-12) var(--sp-6) 0;
	}
	.project-header-text h1 {
		font-size: var(--fs-4xl);
		margin-top: var(--sp-4);
		margin-bottom: var(--sp-3);
		line-height: 1.1;
	}
	.hero-stat-inline {
		font-family: var(--font-mono);
		font-size: var(--fs-xl);
		color: var(--color-ink-muted);
		margin: 0;
	}

	/* ── Metadata bar ── */
	.project-meta-bar {
		border-bottom: 1px solid var(--color-border);
		margin-bottom: var(--sp-12);
	}
	.project-meta-inner {
		max-width: var(--container);
		margin: 0 auto;
		padding: var(--sp-5) var(--sp-6);
		display: flex;
		align-items: center;
		gap: var(--sp-5);
		flex-wrap: wrap;
	}
	.meta-date {
		font-family: var(--font-mono);
		font-size: var(--fs-xs);
		font-weight: 500;
		color: var(--color-ink-muted);
	}

	/* ── Prose ── */
	.project-prose {
		max-width: var(--prose);
		margin: 0 auto;
		padding: 0 var(--sp-6);
	}

	/* ── Responsive ── */
	@media (max-width: 768px) {
		.project-hero {
			aspect-ratio: 16 / 9;
		}
		.hero-title {
			font-size: var(--fs-3xl);
		}
		.hero-stat {
			font-size: var(--fs-xl);
		}
		.hero-inner {
			padding: var(--sp-8) var(--sp-4);
		}
		.project-meta-inner {
			padding: var(--sp-4) var(--sp-4);
		}
		.project-prose {
			padding: 0 var(--sp-4);
		}
	}
</style>
