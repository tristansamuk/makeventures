---
import { getCollection } from 'astro:content';
import BaseHead from '../components/BaseHead.astro';
import Footer from '../components/Footer.astro';
import FormattedDate from '../components/FormattedDate.astro';
import Header from '../components/Header.astro';
import TagList from '../components/TagList.astro';
import { SITE_DESCRIPTION, SITE_TITLE } from '../consts';

const posts = (await getCollection('blog')).sort(
	(a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf(),
);
const recentPosts = posts.slice(0, 3);

const allTags = [...new Set(posts.flatMap((p) => p.data.tags ?? []))];
const postCount = posts.length;
const firstYear = posts.reduce((min, p) => Math.min(min, p.data.pubDate.getFullYear()), Infinity);
---

<!doctype html>
<html lang="en">
	<head>
		<BaseHead title={SITE_TITLE} description={SITE_DESCRIPTION} />
	</head>
	<body>
		<Header />
		<main>
			<section class="hero">
				<p class="hero-label">Field notes from a maker</p>

				<h1 class="hero-title" id="hero-title">
					<span class="title-line">Make-</span>
					<span class="title-line">ventures</span>
				</h1>

				<div class="hero-divider">
					<div class="hero-stats">
						<span><span class="stat-num">{postCount}</span> posts</span>
						<span class="stat-sep">·</span>
						<span><span class="stat-num">{allTags.length}</span> topics</span>
						<span class="stat-sep">·</span>
						<span>since <span class="stat-num">{firstYear}</span></span>
					</div>
					<div class="divider-line"></div>
				</div>

				<div class="hero-bottom">
					<p class="hero-description">{SITE_DESCRIPTION}</p>
					<a href="/blog" class="cta-button">
						Read the blog <span class="arrow" aria-hidden="true">→</span>
					</a>
				</div>

				<div class="hero-topics" aria-label="Topics covered">
					<TagList tags={allTags} />
				</div>
			</section>

			<section class="recent-posts">
				<div class="section-header">
					<h2>Recent Posts</h2>
					<a href="/blog" class="view-all">All posts →</a>
				</div>
				<ul class="post-list" role="list">
					{recentPosts.map((post, i) => (
						<li class="post-item" style={`animation-delay: ${0.1 + i * 0.08}s`}>
							<a href={`/blog/${post.id}/`} class="post-link">
								<div class="post-info">
									<time class="post-date">
										<FormattedDate date={post.data.pubDate} />
									</time>
									<h3 class="post-title">{post.data.title}</h3>
									<p class="post-description">{post.data.description}</p>
								</div>
								<span class="post-arrow" aria-hidden="true">→</span>
							</a>
							{post.data.tags && post.data.tags.length > 0 && (
								<div class="post-tags">
									<TagList tags={post.data.tags} />
								</div>
							)}
						</li>
					))}
				</ul>
			</section>
		</main>
		<Footer />
	</body>
</html>

<script>
	// Typewriter on the eyebrow label — starts after the title has faded in
	const label = document.querySelector('.hero-label') as HTMLElement;
	if (label) {
		const text = label.textContent ?? '';
		label.textContent = '';
		label.setAttribute('aria-label', text);
		label.classList.add('typing');

		let i = 0;
		const speed = 45;
		const startDelay = 800; // let the title land first

		function type() {
			if (i < text.length) {
				label.textContent = text.slice(0, ++i);
				setTimeout(type, speed);
			} else {
				label.classList.remove('typing');
			}
		}
		setTimeout(type, startDelay);
	}

	// Scale hero title so the widest line fills the container width
	function fitTitle() {
		const title = document.getElementById('hero-title') as HTMLElement;
		if (!title) return;
		const containerWidth = (title.parentElement as HTMLElement).clientWidth;
		const lines = title.querySelectorAll<HTMLElement>('.title-line');
		let lo = 10, hi = 400;
		title.style.fontSize = hi + 'px';
		while (hi - lo > 0.5) {
			const mid = (lo + hi) / 2;
			title.style.fontSize = mid + 'px';
			const maxWidth = Math.max(...Array.from(lines).map((l) => l.scrollWidth));
			if (maxWidth <= containerWidth) lo = mid;
			else hi = mid;
		}
		title.style.fontSize = lo + 'px';
	}

	requestAnimationFrame(fitTitle);
	window.addEventListener('resize', fitTitle);
	window.visualViewport?.addEventListener('resize', fitTitle);
</script>

<style>
	/* ── Hero ── */
	.hero {
		padding: var(--sp-16) 0 var(--sp-16);
	}
	.hero-label {
		font-family: var(--font-mono);
		font-size: var(--fs-xs);
		color: var(--color-accent);
		letter-spacing: 0.1em;
		text-transform: uppercase;
		margin: 0 0 var(--sp-5);
		min-height: 1em;
	}
	.hero-label.typing::after {
		content: '▍';
		animation: blink 0.7s step-end infinite;
		margin-left: 1px;
	}
	@keyframes blink {
		0%, 100% { opacity: 1; }
		50%       { opacity: 0; }
	}
	.hero-title {
		font-family: var(--font-display);
		font-weight: 800;
		line-height: 0.75;
		letter-spacing: -0.03em;
		margin: 0 0 var(--sp-6);
		display: flex;
		flex-direction: column;
		animation: fadeUp 0.6s cubic-bezier(0.22, 1, 0.36, 1) both;
		animation-delay: 0.05s;
	}
	.title-line {
		display: block;
		white-space: nowrap;
	}

	/* ── Divider + stats ── */
	.hero-divider {
		display: flex;
		align-items: center;
		gap: var(--sp-6);
		margin-bottom: var(--sp-8);
		animation: fadeUp 0.5s ease both;
		animation-delay: 0.15s;
	}
	.hero-stats {
		display: flex;
		align-items: center;
		gap: var(--sp-3);
		font-family: var(--font-mono);
		font-size: var(--fs-xs);
		color: var(--color-ink-muted);
		white-space: nowrap;
		flex-shrink: 0;
	}
	.stat-num {
		color: var(--color-accent);
		font-weight: 600;
	}
	.stat-sep {
		opacity: 0.4;
	}
	.divider-line {
		flex: 1;
		height: 1px;
		background-color: var(--color-border);
	}

	/* ── Bottom row ── */
	.hero-bottom {
		display: flex;
		align-items: flex-start;
		justify-content: space-between;
		gap: var(--sp-8);
		margin-bottom: var(--sp-8);
		animation: fadeUp 0.6s cubic-bezier(0.22, 1, 0.36, 1) both;
		animation-delay: 0.22s;
	}
	.hero-description {
		font-size: var(--fs-lg);
		color: var(--color-ink-muted);
		line-height: 1.7;
		max-width: 36rem;
		margin: 0;
	}
	.cta-button {
		display: inline-flex;
		align-items: center;
		gap: var(--sp-2);
		padding: var(--sp-3) var(--sp-6);
		background-color: var(--color-accent-subtle);
		color: var(--color-accent);
		text-decoration: none;
		border: 1px solid var(--color-accent);
		border-radius: var(--radius-md);
		font-family: var(--font-mono);
		font-size: var(--fs-sm);
		font-weight: 500;
		letter-spacing: 0.02em;
		white-space: nowrap;
		flex-shrink: 0;
		transition: background-color var(--ease), color var(--ease);
	}
	.cta-button:hover {
		background-color: var(--color-accent);
		color: var(--color-bg);
	}
	.cta-button:hover .arrow {
		transform: translateX(3px);
	}
	.arrow {
		display: inline-block;
		transition: transform var(--ease);
	}

	/* ── Topics strip ── */
	.hero-topics {
		animation: fadeUp 0.6s cubic-bezier(0.22, 1, 0.36, 1) both;
		animation-delay: 0.3s;
	}

	/* ── Recent Posts ── */
	.recent-posts {
		padding-top: var(--sp-16);
		border-top: 1px solid var(--color-border);
		animation: fadeUp 0.6s cubic-bezier(0.22, 1, 0.36, 1) both;
		animation-delay: 0.35s;
	}
	.section-header {
		display: flex;
		align-items: baseline;
		justify-content: space-between;
		margin-bottom: var(--sp-8);
	}
	.section-header h2 {
		margin: 0;
	}
	.view-all {
		font-family: var(--font-mono);
		font-size: var(--fs-xs);
		color: var(--color-ink-muted);
		text-decoration: none;
		letter-spacing: 0.04em;
		transition: color var(--ease);
	}
	.view-all:hover {
		color: var(--color-accent);
	}
	.post-list {
		list-style: none;
		margin: 0;
		padding: 0;
	}
	.post-item {
		border-top: 1px solid var(--color-border-subtle);
		animation: fadeUp 0.5s cubic-bezier(0.22, 1, 0.36, 1) both;
	}
	.post-item:last-child {
		border-bottom: 1px solid var(--color-border-subtle);
	}
	.post-link {
		display: flex;
		align-items: center;
		justify-content: space-between;
		gap: var(--sp-4);
		padding: var(--sp-6) 0 var(--sp-3);
		text-decoration: none;
		color: inherit;
	}
	.post-info {
		flex: 1;
		min-width: 0;
	}
	.post-date {
		display: block;
		font-family: var(--font-mono);
		font-size: var(--fs-xs);
		font-weight: 500;
		letter-spacing: 0.06em;
		color: var(--color-accent);
		margin-bottom: var(--sp-1);
	}
	.post-title {
		font-family: var(--font-display);
		font-size: var(--fs-xl);
		font-weight: 700;
		margin: 0 0 var(--sp-1);
		transition: color var(--ease);
		line-height: 1.3;
	}
	.post-link:hover .post-title {
		color: var(--color-accent);
	}
	.post-description {
		margin: 0;
		font-size: var(--fs-sm);
		color: var(--color-ink-muted);
		line-height: 1.6;
	}
	.post-arrow {
		font-size: var(--fs-xl);
		color: var(--color-border);
		flex-shrink: 0;
		transition: color var(--ease), transform var(--ease);
	}
	.post-link:hover .post-arrow {
		color: var(--color-accent);
		transform: translateX(4px);
	}
	.post-tags {
		padding-bottom: var(--sp-5);
	}

	@keyframes fadeUp {
		from { opacity: 0; transform: translateY(20px); }
		to   { opacity: 1; transform: translateY(0); }
	}

	@media (prefers-reduced-motion: reduce) {
		.hero-label, .hero-title, .hero-divider, .hero-bottom,
		.hero-topics, .recent-posts, .post-item {
			animation: none;
		}
	}

	@media (max-width: 768px) {
		.hero { padding: var(--sp-10) 0 var(--sp-12); }
		.hero-bottom {
			flex-direction: column;
			gap: var(--sp-5);
		}
		.hero-description { font-size: var(--fs-md); }
		.hero-stats { font-size: var(--fs-xs); gap: var(--sp-2); }
	}
</style>
