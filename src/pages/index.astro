---
import { getCollection } from 'astro:content';
import BaseHead from '../components/BaseHead.astro';
import ComputerChipIcon from '../components/ComputerChipIcon.astro';
import Footer from '../components/Footer.astro';
import FormattedDate from '../components/FormattedDate.astro';
import Header from '../components/Header.astro';
import TagList from '../components/TagList.astro';
import { SITE_DESCRIPTION, SITE_TITLE } from '../consts';

const recentPosts = (await getCollection('blog'))
	.sort((a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf())
	.slice(0, 3);
---

<!doctype html>
<html lang="en">
	<head>
		<BaseHead title={SITE_TITLE} description={SITE_DESCRIPTION} />
	</head>
	<body>
		<Header />
		<main>
			<section class="hero">
				<div class="hero-text">
					<p class="hero-label">Field notes from a maker</p>
					<h1>{SITE_TITLE}</h1>
					<p class="hero-description">{SITE_DESCRIPTION}</p>
					<a href="/blog" class="cta-button">Read the blog <span class="arrow" aria-hidden="true">→</span></a>
				</div>
				<div class="hero-icon-wrap">
					<ComputerChipIcon class="hero-icon" />
				</div>
			</section>

			<section class="recent-posts">
				<div class="section-header">
					<h2>Recent Posts</h2>
					<a href="/blog" class="view-all">All posts →</a>
				</div>
				<ul class="post-list" role="list">
					{recentPosts.map((post, i) => (
						<li class="post-item" style={`animation-delay: ${0.1 + i * 0.08}s`}>
							<a href={`/blog/${post.id}/`} class="post-link">
								<div class="post-info">
									<time class="post-date">
										<FormattedDate date={post.data.pubDate} />
									</time>
									<h3 class="post-title">{post.data.title}</h3>
									<p class="post-description">{post.data.description}</p>
								</div>
								<span class="post-arrow" aria-hidden="true">→</span>
							</a>
							{post.data.tags && post.data.tags.length > 0 && (
								<div class="post-tags">
									<TagList tags={post.data.tags} />
								</div>
							)}
						</li>
					))}
				</ul>
			</section>
		</main>
		<Footer />
	</body>
</html>

<style>
	/* ── Hero ── */
	.hero {
		display: grid;
		grid-template-columns: 1fr 320px;
		align-items: center;
		gap: var(--sp-16);
		padding: var(--sp-20) 0 var(--sp-16);
	}
	.hero-label {
		font-family: var(--font-mono);
		font-size: var(--fs-xs);
		color: var(--color-accent);
		letter-spacing: 0.08em;
		text-transform: uppercase;
		margin-bottom: var(--sp-4);
		animation: fadeUp 0.5s ease both;
		animation-delay: 0.05s;
	}
	.hero h1 {
		font-size: var(--fs-5xl);

		margin-bottom: var(--sp-5);
		line-height: 1.05;
		animation: fadeUp 0.6s cubic-bezier(0.22, 1, 0.36, 1) both;
		animation-delay: 0.1s;
	}
	.hero-description {
		font-size: var(--fs-lg);
		color: var(--color-ink-muted);
		margin-bottom: var(--sp-8);
		line-height: 1.7;
		max-width: 38rem;
		animation: fadeUp 0.6s cubic-bezier(0.22, 1, 0.36, 1) both;
		animation-delay: 0.18s;
	}
	.cta-button {
		display: inline-flex;
		align-items: center;
		gap: var(--sp-2);
		padding: var(--sp-3) var(--sp-6);
		background-color: var(--color-accent-subtle);
		color: var(--color-accent);
		text-decoration: none;
		border: 1px solid var(--color-accent);
		border-radius: var(--radius-md);
		font-family: var(--font-mono);
		font-size: var(--fs-sm);
		font-weight: 500;
		letter-spacing: 0.02em;
		transition: background-color var(--ease), transform var(--ease);
		animation: fadeUp 0.6s cubic-bezier(0.22, 1, 0.36, 1) both;
		animation-delay: 0.26s;
	}
	.cta-button:hover {
		background-color: var(--color-accent);
		color: var(--color-bg);
	}
	.cta-button:hover .arrow {
		transform: translateX(3px);
	}
	.arrow {
		display: inline-block;
		transition: transform var(--ease);
	}
	.hero-icon-wrap {
		animation: fadeIn 0.4s ease both;
		animation-delay: 0.05s;
	}
	.hero-icon {
		width: 100%;
		height: auto;
		color: var(--color-accent);
		opacity: 0.18;
		transition: opacity var(--ease);
	}
	.hero-icon-wrap:hover .hero-icon {
		opacity: 0.28;
	}

	/* ── Recent Posts ── */
	.recent-posts {
		padding-top: var(--sp-16);
		border-top: 1px solid var(--color-border);
		animation: fadeUp 0.6s cubic-bezier(0.22, 1, 0.36, 1) both;
		animation-delay: 0.35s;
	}
	.section-header {
		display: flex;
		align-items: baseline;
		justify-content: space-between;
		margin-bottom: var(--sp-8);
	}
	.section-header h2 {
		margin: 0;

	}
	.view-all {
		font-family: var(--font-mono);
		font-size: var(--fs-xs);
		color: var(--color-ink-muted);
		text-decoration: none;
		letter-spacing: 0.04em;
		transition: color var(--ease);
	}
	.view-all:hover {
		color: var(--color-accent);
	}

	.post-list {
		list-style: none;
		margin: 0;
		padding: 0;
	}
	.post-item {
		border-top: 1px solid var(--color-border-subtle);
		animation: fadeUp 0.5s cubic-bezier(0.22, 1, 0.36, 1) both;
	}
	.post-item:last-child {
		border-bottom: 1px solid var(--color-border-subtle);
	}
	.post-link {
		display: flex;
		align-items: center;
		justify-content: space-between;
		gap: var(--sp-4);
		padding: var(--sp-6) 0 var(--sp-3);
		text-decoration: none;
		color: inherit;
	}
	.post-info {
		flex: 1;
		min-width: 0;
	}
	.post-date {
		display: block;
		font-family: var(--font-mono);
		font-size: var(--fs-xs);
		font-weight: 500;
		letter-spacing: 0.06em;
		color: var(--color-accent);
		margin-bottom: var(--sp-1);
	}
	.post-title {
		font-family: var(--font-display);
		font-size: var(--fs-xl);
		font-weight: 700;
		margin: 0 0 var(--sp-1);
		transition: color var(--ease);
		line-height: 1.3;
	}
	.post-link:hover .post-title {
		color: var(--color-accent);
	}
	.post-description {
		margin: 0;
		font-size: var(--fs-sm);
		color: var(--color-ink-muted);
		line-height: 1.6;
	}
	.post-arrow {
		font-size: var(--fs-xl);
		color: var(--color-border);
		flex-shrink: 0;
		transition: color var(--ease), transform var(--ease);
	}
	.post-link:hover .post-arrow {
		color: var(--color-accent);
		transform: translateX(4px);
	}
	.post-tags {
		padding-bottom: var(--sp-5);
	}

	@keyframes fadeUp {
		from { opacity: 0; transform: translateY(20px); }
		to   { opacity: 1; transform: translateY(0); }
	}
	@keyframes fadeIn {
		from { opacity: 0; }
		to   { opacity: 1; }
	}

	@media (prefers-reduced-motion: reduce) {
		.hero-label, .hero h1, .hero-description, .cta-button,
		.hero-icon-wrap, .recent-posts, .post-item {
			animation: none;
		}
	}

	@media (max-width: 768px) {
		.hero {
			grid-template-columns: 1fr;
			padding: var(--sp-12) 0 var(--sp-10);
			gap: var(--sp-8);
		}
		.hero-icon-wrap { display: none; }
		.hero-description { font-size: var(--fs-md); }
	}
</style>
