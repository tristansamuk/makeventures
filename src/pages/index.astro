---
import { getCollection } from 'astro:content';
import BaseHead from '../components/BaseHead.astro';
import ComputerChipIcon from '../components/ComputerChipIcon.astro';
import Footer from '../components/Footer.astro';
import FormattedDate from '../components/FormattedDate.astro';
import Header from '../components/Header.astro';
import { SITE_DESCRIPTION, SITE_TITLE } from '../consts';

const recentPosts = (await getCollection('blog'))
	.sort((a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf())
	.slice(0, 3);
---

<!doctype html>
<html lang="en">
	<head>
		<BaseHead title={SITE_TITLE} description={SITE_DESCRIPTION} />
	</head>
	<body>
		<Header />
		<main>
			<section class="hero">
				<div class="hero-text">
					<h1>{SITE_TITLE}</h1>
					<p class="hero-description">{SITE_DESCRIPTION}</p>
					<a href="/blog" class="cta-button">Read the blog &rarr;</a>
				</div>
				<ComputerChipIcon class="hero-icon" />
			</section>

			<section class="recent-posts">
				<div class="section-header">
					<h2>Recent Posts</h2>
					<a href="/blog" class="view-all">View all &rarr;</a>
				</div>
				<ul class="post-list" role="list">
					{recentPosts.map((post) => (
						<li class="post-item">
							<a href={`/blog/${post.id}/`} class="post-link">
								<div class="post-info">
									<time class="post-date">
										<FormattedDate date={post.data.pubDate} />
									</time>
									<h3 class="post-title">{post.data.title}</h3>
									<p class="post-description">{post.data.description}</p>
								</div>
								<span class="post-arrow" aria-hidden="true">&rarr;</span>
							</a>
						</li>
					))}
				</ul>
			</section>
		</main>
		<Footer />
	</body>
</html>

<style>
	.hero {
		display: grid;
		grid-template-columns: 1fr 400px;
		align-items: center;
		gap: var(--sp-12);
		padding: var(--sp-20) 0 var(--sp-16);
	}
	.hero-text {
		max-width: var(--prose);
	}
	.hero h1 {
		font-size: var(--fs-5xl);
		margin-bottom: var(--sp-4);
		line-height: 1.1;
	}
	.hero-description {
		font-size: var(--fs-xl);
		color: var(--color-ink-muted);
		margin-bottom: var(--sp-8);
		line-height: 1.6;
	}
	.hero-icon {
		width: 100%;
		height: auto;
		color: var(--color-ink);
		opacity: 0.12;
		transition: color var(--ease);
		animation: chipIn 0.2s ease both;
	}
	.hero h1 {
		animation: slideUp 0.7s cubic-bezier(0.22, 1, 0.36, 1) both;
		animation-delay: 0.05s;
	}
	.hero-description {
		animation: slideUp 0.7s cubic-bezier(0.22, 1, 0.36, 1) both;
		animation-delay: 0.15s;
	}
	.cta-button {
		display: inline-flex;
		align-items: center;
		padding: var(--sp-3) var(--sp-6);
		background-color: var(--color-accent);
		color: #fff;
		text-decoration: none;
		border-radius: var(--radius-md);
		font-size: var(--fs-sm);
		font-weight: 600;
		letter-spacing: 0.02em;
		transition: background-color var(--ease), transform var(--ease);
	}
	.cta-button:hover {
		background-color: var(--color-accent-hover);
		color: #fff;
		transform: translateX(2px);
	}
	.cta-button {
		animation: slideUp 0.7s cubic-bezier(0.22, 1, 0.36, 1) both;
		animation-delay: 0.25s;
	}

	.recent-posts {
		padding-top: var(--sp-16);
		border-top: 1px solid var(--color-border);
		animation: slideUp 0.7s cubic-bezier(0.22, 1, 0.36, 1) both;
		animation-delay: 0.4s;
	}
	.section-header {
		display: flex;
		align-items: baseline;
		justify-content: space-between;
		margin-bottom: var(--sp-8);
	}
	.section-header h2 {
		margin: 0;
	}
	.view-all {
		font-size: var(--fs-sm);
		color: var(--color-ink-muted);
		text-decoration: none;
		transition: color var(--ease);
	}
	.view-all:hover {
		color: var(--color-accent);
	}

	.post-list {
		list-style: none;
		margin: 0;
		padding: 0;
	}
	.post-item {
		border-top: 1px solid var(--color-border);
	}
	.post-item:last-child {
		border-bottom: 1px solid var(--color-border);
	}
	.post-link {
		display: flex;
		align-items: center;
		justify-content: space-between;
		gap: var(--sp-4);
		padding: var(--sp-6) 0;
		text-decoration: none;
		color: inherit;
	}
	.post-date {
		display: block;
		font-size: var(--fs-xs);
		font-weight: 600;
		letter-spacing: 0.08em;
		text-transform: uppercase;
		color: var(--color-accent);
		margin-bottom: var(--sp-1);
	}
	.post-title {
		font-size: var(--fs-lg);
		margin: 0 0 var(--sp-1);
		transition: color var(--ease);
	}
	.post-link:hover .post-title {
		color: var(--color-accent);
	}
	.post-description {
		margin: 0;
		font-size: var(--fs-sm);
		color: var(--color-ink-muted);
	}
	.post-arrow {
		font-size: var(--fs-xl);
		color: var(--color-ink-muted);
		flex-shrink: 0;
		transition: color var(--ease), transform var(--ease);
	}
	.post-link:hover .post-arrow {
		color: var(--color-accent);
		transform: translateX(4px);
	}

	@keyframes slideUp {
		from {
			opacity: 0;
			transform: translateY(28px);
		}
		to {
			opacity: 1;
			transform: translateY(0);
		}
	}

	@keyframes chipIn {
		from { opacity: 0; }
		to   { opacity: 0.12; }
	}

	@media (prefers-reduced-motion: reduce) {
		.hero h1,
		.hero-description,
		.cta-button,
		.hero-icon,
		.recent-posts {
			animation: none;
		}
	}

	@media (max-width: 768px) {
		.hero {
			grid-template-columns: 1fr;
			padding: var(--sp-12) 0 var(--sp-10);
		}
		.hero-icon {
			display: none;
		}
		.hero-description {
			font-size: var(--fs-md);
		}
	}
</style>
