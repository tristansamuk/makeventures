---
import { runSDK, SDKCoreJs } from 'studiocms:sdk';
import BaseHead from '../../../components/BaseHead.astro';
import Footer from '../../../components/Footer.astro';
import Header from '../../../components/Header.astro';
import PostCard from '../../../components/PostCard.astro';
import { SITE_TITLE } from '../../../consts';

const { tag } = Astro.params;

if (!tag) {
	return new Response(null, { status: 404 });
}

const allPages = await runSDK(SDKCoreJs.GET.pages());
const posts = allPages
	.filter((p) => p.package === '@studiocms/blog')
	.filter((p) => p.tags?.some((t) => t.slug === tag || t.name === tag))
	.sort((a, b) => {
		const aDate = a.publishedAt?.valueOf() ?? 0;
		const bDate = b.publishedAt?.valueOf() ?? 0;
		return bDate - aDate;
	});
---

<!doctype html>
<html lang="en">
	<head>
		<BaseHead
			title={`#${tag} — ${SITE_TITLE}`}
			description={`All posts tagged with "${tag}"`}
		/>
	</head>
	<body>
		<Header />
		<main>
			<header class="page-header">
				<p class="page-eyebrow">Tag</p>
				<h1>{tag}</h1>
				<p class="page-subtitle">
					{posts.length} post{posts.length !== 1 ? 's' : ''}
				</p>
			</header>

			<ul class="post-grid" role="list">
				{posts.map((post) => <PostCard post={post} />)}
			</ul>
		</main>
		<Footer />
	</body>
</html>

<style>
	.page-header {
		margin-bottom: var(--sp-12);
		padding-bottom: var(--sp-8);
		border-bottom: 1px solid var(--color-border);
	}
	.page-eyebrow {
		font-family: var(--font-mono);
		font-size: var(--fs-xs);
		font-weight: 500;
		text-transform: uppercase;
		color: var(--color-accent);
		margin: 0 0 var(--sp-2);
	}
	.page-header h1 {
		margin-bottom: var(--sp-2);
	}
	.page-subtitle {
		font-family: var(--font-mono);
		font-size: var(--fs-sm);
		color: var(--color-ink-muted);
		margin: 0;
	}
	.post-grid {
		list-style: none;
		margin: 0;
		padding: 0;
		display: grid;
		grid-template-columns: repeat(2, 1fr);
		gap: var(--sp-8);
	}
	@media (max-width: 720px) {
		.post-grid {
			grid-template-columns: 1fr;
			gap: var(--sp-5);
		}
	}
</style>
